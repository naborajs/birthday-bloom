# 🎂 BIRTHDAY BLOOM — PRODUCTION BLUEPRINT
# -------------------------------------------------------------------------
# This is the master configuration file for the Cinematic Birthday Engine.
# Copy this file to .env and customize it for your "Secret Surprise" launch.
# -------------------------------------------------------------------------

# 🗝️ IDENTITY (Mandatory)
# -------------------------------------------------------------------------
# The name of the birthday person. (Example: "Nishant")
# IMPORTANT: Setting this skips the setup wizard and starts the surprise instantly.
VITE_BIRTHDAY_NAME="Nishant"

# 🎭 CINEMATIC TEMPLATE
# -------------------------------------------------------------------------
# Choose the relationship to trigger specific UI, Fonts, and Pacing:
# - "partner" : Romantic, slow-burn, serif fonts, hearts & roses.
# - "friend"  : High-energy, fast-paced, bold fonts, party vibes.
# - "family"  : Warm, sentimental, clean fonts, balloons & glows.
VITE_BIRTHDAY_RELATIONSHIP="friend"

# 🎂 PERSONAL DETAILS
# -------------------------------------------------------------------------
VITE_BIRTHDAY_AGE=25
VITE_BIRTHDAY_GENDER="male"
VITE_BIRTHDAY_DATE="2026-04-24T00:00:00"

# 🎨 DESIGN SYSTEM
# -------------------------------------------------------------------------
# Global accent color (Hex). Drives glows, buttons, and heart-tree blooms.
VITE_BIRTHDAY_COLOR="#FF6B6B"

# Comma-separated interests. (Example: "Gaming,Coding,Cars")
VITE_BIRTHDAY_INTERESTS="Gaming,Coding,Cars"

# The grand finale message. Use \n for line breaks.
VITE_BIRTHDAY_CUSTOM_MESSAGE="You are a legend! Have the best birthday ever! 🚀"

# 🖼️ CINEMATIC MEDIA
# -------------------------------------------------------------------------
# Add up to 3 high-quality photo URLs for the 3D Gallery.
# If left empty, the engine will use premium default placeholders.
VITE_PHOTO_1="https://images.unsplash.com/photo-1530101121243-c99ff3cdca42"
VITE_PHOTO_2=""
VITE_PHOTO_3=""

# Audio (Direct URL to .mp3). Optional.
VITE_SOUND_URL=""

# 🛠️ ADVANCED SETTINGS (Optional)
# -------------------------------------------------------------------------
# Force high-performance mode or specific animation speeds.
VITE_ANIMATION_SPEED="moderate" # slow | moderate | fast
VITE_PARTICLE_COUNT=25